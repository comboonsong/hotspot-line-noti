# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# LINE Group ID (ใช้สำหรับส่งข้อความเข้ากลุ่ม — ดูวิธีหาใน README)
LINE_GROUP_ID=your_line_group_id_here

# Province filter (ชื่อจังหวัดภาษาไทย)
PROVINCE_FILTER=ลำพูน

# Schedule times (comma-separated, 24hr format)
SCHEDULE_TIMES=01:00,03:00,06:00,14:00

# Message format: satellite | district | both
MESSAGE_MODE=satellite
